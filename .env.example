# =============================================================================
# U+ Revai — Variables de entorno globales
# Copia este archivo a .env en la raíz y rellena los valores reales
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos (Supabase / PostgreSQL)
# -----------------------------------------------------------------------------
# Conexión pooled (para consultas de app)
DATABASE_URL=""

# Conexión directa (para migraciones Prisma)
DIRECT_URL=""

# -----------------------------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------------------------
# URL del proyecto Supabase
SUPABASE_URL=""
# Clave anónima (pública) de Supabase — obtener de Supabase Dashboard > Settings > API
SUPABASE_ANON_KEY=""
# Clave de servicio (service_role) — solo para backend, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=""

# -----------------------------------------------------------------------------
# URLs de producción de cada servicio (Vercel)
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=""
ANALYSIS_SERVICE_URL=""
REVIEW_SERVICE_URL=""
REPORT_SERVICE_URL=""
SURVEYS_SERVICE_URL=""
FRONTEND_URL=""

# -----------------------------------------------------------------------------
# URLs locales de cada servicio (solo para desarrollo)
# -----------------------------------------------------------------------------
# AUTH_SERVICE_URL="http://localhost:3001"
# ANALYSIS_SERVICE_URL="http://localhost:3002"
# REVIEW_SERVICE_URL="http://localhost:3003"
# REPORT_SERVICE_URL="http://localhost:3004"
# SURVEYS_SERVICE_URL="http://localhost:3005"
# AI_SERVICE_URL="http://localhost:8000"
# FRONTEND_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# URLs públicas del frontend (Next.js NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_SERVICE_URL=""
NEXT_PUBLIC_REVIEW_SERVICE_URL=""
NEXT_PUBLIC_ANALYSIS_SERVICE_URL=""
NEXT_PUBLIC_REPORT_SERVICE_URL=""
NEXT_PUBLIC_SURVEYS_SERVICE_URL=""

# -----------------------------------------------------------------------------
# Servicio AI (app-ai-service)
# -----------------------------------------------------------------------------
APP_NAME="app-ai-service"
APP_ENV="development"
APP_HOST="0.0.0.0"
APP_PORT="8000"

# Token opcional para autenticación servicio-a-servicio
INTERNAL_SERVICE_TOKEN=""

# Proveedor de IA: gemini | openai | anthropic
AI_PROVIDER="gemini"
AI_MODEL="gemini-2.5-flash"
AI_API_KEY=""
