# -----------------------------------------------------------------------------
# App identity and runtime
# -----------------------------------------------------------------------------
# Nombre visible del servicio. Normalmente no hace falta cambiarlo.
APP_NAME="app-ai-service"

# development | staging | production
APP_ENV="development"

# Host y puerto donde FastAPI escuchara dentro del proceso.
# En Docker conviene dejar APP_HOST="0.0.0.0".
APP_HOST="0.0.0.0"
APP_PORT="8000"

# -----------------------------------------------------------------------------
# Internal service URLs
# -----------------------------------------------------------------------------
# Si corres app-ai-service de forma local y los otros servicios tambien localmente,
# usa localhost con el puerto real de cada servicio.
#
# Si corres app-ai-service dentro de Docker pero review/surveys/report viven en tu
# maquina host, usa host.docker.internal para llegar desde el contenedor al host.
# El compose incluido ya agrega ese hostname en Linux.
#
# Ejemplo local:
# REVIEW_SERVICE_URL="http://localhost:3003"
# SURVEYS_SERVICE_URL="http://localhost:3005"
# REPORT_SERVICE_URL="http://localhost:3004"
#
# Ejemplo Docker -> host:
# REVIEW_SERVICE_URL="http://host.docker.internal:3003"
# SURVEYS_SERVICE_URL="http://host.docker.internal:3005"
# REPORT_SERVICE_URL="http://host.docker.internal:3004"
REVIEW_SERVICE_URL="http://localhost:3003"
SURVEYS_SERVICE_URL="http://localhost:3005"
REPORT_SERVICE_URL="http://localhost:3004"

# Token opcional para autenticacion servicio-a-servicio.
# Si review/surveys/report no exigen autenticacion interna todavia, puede quedar vacio.
INTERNAL_SERVICE_TOKEN=""

# -----------------------------------------------------------------------------
# AI provider configuration
# -----------------------------------------------------------------------------
# Proveedor de IA actual o futuro. Ejemplos: gemini, openai, anthropic.
AI_PROVIDER="gemini"

# Modelo a usar en el proveedor elegido.
# Ajustalo cuando cambien costo, velocidad o calidad esperada.
AI_MODEL="gemini-2.5-flash"

# Credencial del proveedor de IA.
# No debe versionarse y normalmente se completa solo en .env local o en el entorno
# real de despliegue.
AI_API_KEY=""

