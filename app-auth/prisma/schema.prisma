// NO SE TOCA!!!
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// NO SE TOCA!!!
// ---------------------------

enum RoleName {
  ADMIN
  TRABAJADOR
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model AppUser {
  /// Debe coincidir con el `auth.users.id` de Supabase Auth.
  id                   String               @id @db.Uuid
  email                String               @unique
  fullName             String?              @map("full_name")
  /// Descripción interna del usuario dentro del sistema.
  /// Ejemplo: "Administrador principal de la cuenta" o "Trabajador encargado de responder reviews".
  description          String?
  isActive             Boolean              @default(true) @map("is_active")
  memberships          BusinessMembership[]
  grantedBranchAccesses UserBranchAccess[]  @relation("BranchAccessGrantedBy")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  @@map("app_users")
}

model Business {
  id          String               @id @default(uuid()) @db.Uuid
  name        String
  slug        String               @unique
  description String?
  isActive    Boolean              @default(true) @map("is_active")
  branches    Branch[]
  memberships BusinessMembership[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  @@map("businesses")
}

model Branch {
  id          String             @id @default(uuid()) @db.Uuid
  businessId  String             @map("business_id") @db.Uuid
  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  isActive    Boolean            @default(true) @map("is_active")
  userAccesses UserBranchAccess[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  @@unique([businessId, slug])
  @@unique([id, businessId])
  @@index([businessId])
  @@map("branches")
}

model BusinessMembership {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @map("user_id") @db.Uuid
  businessId          String             @map("business_id") @db.Uuid
  roleId              String             @map("role_id") @db.Uuid
  user                AppUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  business            Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role                Role               @relation(fields: [roleId], references: [id])
  isOwner             Boolean            @default(false) @map("is_owner")
  isActive            Boolean            @default(true) @map("is_active")
  hasFullBranchAccess Boolean            @default(false) @map("has_full_branch_access")
  branchAccesses      UserBranchAccess[]
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  @@unique([userId, businessId])
  @@index([businessId])
  @@index([roleId])
  @@map("business_memberships")
}

model UserBranchAccess {
  userId          String             @map("user_id") @db.Uuid
  businessId      String             @map("business_id") @db.Uuid
  branchId        String             @map("branch_id") @db.Uuid
  grantedByUserId String?            @map("granted_by_user_id") @db.Uuid
  membership      BusinessMembership @relation(fields: [userId, businessId], references: [userId, businessId], onDelete: Cascade)
  branch          Branch             @relation(fields: [branchId, businessId], references: [id, businessId], onDelete: Cascade)
  grantedByUser   AppUser?           @relation("BranchAccessGrantedBy", fields: [grantedByUserId], references: [id])
  createdAt       DateTime           @default(now()) @map("created_at")
  @@id([userId, branchId])
  @@index([businessId])
  @@index([branchId])
  @@map("user_branch_accesses")
}

model Role {
  id          String               @id @default(uuid()) @db.Uuid
  name        RoleName             @unique
  /// Descripción del rol.
  /// Ejemplo: "Usuario administrador con acceso completo al sistema".
  description String?
  canLogin    Boolean              @default(true) @map("can_login")
  memberships BusinessMembership[]
  permissions RoleEndpointPermission[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  @@map("roles")
}

model Endpoint {
  id          String     @id @default(uuid()) @db.Uuid
  key         String     @unique
  method      HttpMethod
  path        String
  /// Descripción del endpoint.
  /// Ejemplo: "Permite listar las reviews del negocio".
  description String?
  isActive    Boolean    @default(true) @map("is_active")
  permissions RoleEndpointPermission[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  @@unique([method, path])
  @@map("endpoints")
}

model RoleEndpointPermission {
  roleId     String   @map("role_id") @db.Uuid
  endpointId String   @map("endpoint_id") @db.Uuid
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  endpoint   Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  /// Descripción del permiso.
  /// Ejemplo: "Permite que el rol ADMIN pueda eliminar reviews".
  description String?
  allowed    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  @@id([roleId, endpointId])
  @@map("role_endpoint_permissions")
}