generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model app_users {
  id                   String                 @id @db.Uuid
  email                String                 @unique
  full_name            String?
  description          String?
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now())
  updated_at           DateTime
  business_memberships business_memberships[]
  user_branch_accesses user_branch_accesses[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model branches {
  id                   String                 @id @db.Uuid
  business_id          String                 @db.Uuid
  name                 String
  slug                 String
  description          String?
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now())
  updated_at           DateTime
  businesses           businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade)
  user_branch_accesses user_branch_accesses[]

  @@unique([business_id, slug])
  @@unique([id, business_id])
  @@index([business_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model business_memberships {
  id                     String                 @id @db.Uuid
  user_id                String                 @db.Uuid
  business_id            String                 @db.Uuid
  role_id                String                 @db.Uuid
  is_owner               Boolean                @default(false)
  is_active              Boolean                @default(true)
  has_full_branch_access Boolean                @default(false)
  created_at             DateTime               @default(now())
  updated_at             DateTime
  businesses             businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade)
  roles                  roles                  @relation(fields: [role_id], references: [id])
  app_users              app_users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_branch_accesses   user_branch_accesses[]

  @@unique([user_id, business_id])
  @@index([business_id])
  @@index([role_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model businesses {
  id                   String                 @id @db.Uuid
  name                 String
  slug                 String                 @unique
  description          String?
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now())
  updated_at           DateTime
  branches             branches[]
  business_memberships business_memberships[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model endpoints {
  id                        String                      @id @db.Uuid
  key                       String                      @unique
  method                    HttpMethod
  path                      String
  description               String?
  is_active                 Boolean                     @default(true)
  created_at                DateTime                    @default(now())
  updated_at                DateTime
  role_endpoint_permissions role_endpoint_permissions[]

  @@unique([method, path])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model role_endpoint_permissions {
  role_id     String    @db.Uuid
  endpoint_id String    @db.Uuid
  description String?
  allowed     Boolean   @default(true)
  created_at  DateTime  @default(now())
  endpoints   endpoints @relation(fields: [endpoint_id], references: [id], onDelete: Cascade)
  roles       roles     @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, endpoint_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model roles {
  id                        String                      @id @db.Uuid
  name                      RoleName                    @unique
  description               String?
  can_login                 Boolean                     @default(true)
  created_at                DateTime                    @default(now())
  updated_at                DateTime
  business_memberships      business_memberships[]
  role_endpoint_permissions role_endpoint_permissions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_branch_accesses {
  user_id              String               @db.Uuid
  business_id          String               @db.Uuid
  branch_id            String               @db.Uuid
  granted_by_user_id   String?              @db.Uuid
  created_at           DateTime             @default(now())
  branches             branches             @relation(fields: [branch_id, business_id], references: [id, business_id], onDelete: Cascade)
  app_users            app_users?           @relation(fields: [granted_by_user_id], references: [id])
  business_memberships business_memberships @relation(fields: [user_id, business_id], references: [user_id, business_id], onDelete: Cascade)

  @@id([user_id, branch_id])
  @@index([branch_id])
  @@index([business_id])
}

model Survey {
  id         String           @id @default(uuid())
  businessId String
  branchId   String?
  title      String
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  questions  SurveyQuestion[]
  responses  SurveyResponse[]

  @@map("surveys")
}

model SurveyQuestion {
  id        String         @id @default(uuid())
  surveyId  String
  text      String
  type      QuestionType
  order     Int
  createdAt DateTime       @default(now())
  answers   SurveyAnswer[]
  survey    Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("survey_questions")
}

model SurveyResponse {
  id         String         @id @default(uuid())
  surveyId   String
  businessId String
  branchId   String?
  createdAt  DateTime       @default(now())
  answers    SurveyAnswer[]
  survey     Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("survey_responses")
}

model SurveyAnswer {
  id         String         @id @default(uuid())
  responseId String
  questionId String
  value      String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@map("survey_answers")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum RoleName {
  ADMIN
  TRABAJADOR
}

enum QuestionType {
  TEXT
  RATING
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}
