{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["esnext"],
        "ignoreDeprecations": "6.0",
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,

        "baseUrl": ".",
        "types": ["node"]
    },
    "include": ["prisma.config.ts", "test-prisma.ts"]
}
